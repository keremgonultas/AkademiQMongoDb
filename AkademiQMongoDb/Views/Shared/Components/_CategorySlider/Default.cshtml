@model List<AkademiQMongoDb.DTOs.CategoryDtos.ResultCategoryDto>

<div class="food-cat-area default-padding bg-gray" style="background-image: url(/UI/assets/img/shape/3.png);">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 offset-lg-2">
                <div class="site-heading text-center">
                    <h4 class="sub-title">YEMEK KATEGORİLERİ</h4>
                    <h2 class="title split-text">Menümüzün En Popüler Kategorileri</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="food-cat-carousel text-light swiper">
                    <div class="swiper-wrapper">

                        @foreach (var item in Model)
                        {
                            <div class="swiper-slide">
                                <div class="food-cat-item">
                                    <a href="/Product/Index?category=@item.Name" style="background-image: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.85) 100%), url('@item.ImageUrl');">
                                        <h4 style="color: #ffffff; text-shadow: 2px 2px 8px rgba(0,0,0,0.9); font-weight: 800;">
                                            @item.Name
                                        </h4>
                                        <span style="color: #ffffff; text-shadow: 1px 1px 5px rgba(0,0,0,0.9); font-weight: 600;">
                                            Keşfet <i class="fas fa-arrow-right"></i>
                                        </span>
                                    </a>
                                </div>
                            </div>
                        }

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>