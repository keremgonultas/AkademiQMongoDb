@inject AkademiQMongoDb.Services.ContactServices.IContactService ContactService
@inject AkademiQMongoDb.Services.ReservationServices.IReservationService ReservationService

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();

    
    var messages = await ContactService.GetAllAsync();
    var unreadMessageCount = messages.Count(x => x.IsRead == false);

    
    var reservations = await ReservationService.GetAllAsync();
    var pendingReservationCount = reservations.Count(x => x.Status == "Onay Bekliyor");
}
