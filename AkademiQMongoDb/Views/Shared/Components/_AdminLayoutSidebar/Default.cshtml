@inject AkademiQMongoDb.Services.ContactServices.IContactService ContactService
@inject AkademiQMongoDb.Services.ReservationServices.IReservationService ReservationService

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();

    
    var messages = await ContactService.GetAllAsync();
    var unreadMessageCount = messages.Count(x => x.IsRead == false);

    
    var reservations = await ReservationService.GetAllAsync();
    var pendingReservationCount = reservations.Count(x => x.Status == "Onay Bekliyor");
}
<aside class="flex w-64 flex-col bg-gradient-to-b from-red-600 to-red-900 text-white shadow-2xl h-screen sticky top-0">
    <div class="flex h-full min-h-0 flex-col justify-between p-4">
        <div class="flex flex-col gap-4">

            <div class="flex items-center gap-3 px-3 py-3 border-b border-red-400/30 mb-2">
                <div class="bg-center bg-no-repeat aspect-square bg-cover rounded-full size-12 border-2 border-white shadow-md" data-alt="Admin Profile" style='background-image: url("https://ui-avatars.com/api/?name=Admin&background=ffffff&color=dc2626&bold=true");'></div>
                <div class="flex flex-col">
                    <h1 class="text-white text-lg font-bold leading-normal tracking-wider">FOODU</h1>
                    <p class="text-red-200 text-xs font-medium leading-normal uppercase tracking-widest">Yönetim Paneli</p>
                </div>
            </div>

            <nav class="flex flex-col gap-2">

                <a class="flex items-center gap-3 px-3 py-3 rounded-lg transition-all duration-300 @(currentController == "Dashboard" ? "bg-white/20 border-l-4 border-white font-bold shadow-lg" : "hover:bg-white/10 hover:translate-x-1 text-red-100 hover:text-white")" href="/Admin/Dashboard/Index">
                    <span class="material-symbols-outlined">dashboard</span>
                    <p class="text-sm leading-normal">Dashboard</p>
                </a>

                <a class="flex items-center gap-3 px-3 py-3 rounded-lg transition-all duration-300 @(currentController == "Category" ? "bg-white/20 border-l-4 border-white font-bold shadow-lg" : "hover:bg-white/10 hover:translate-x-1 text-red-100 hover:text-white")" href="/Admin/Category/Index">
                    <span class="material-symbols-outlined">list</span>
                    <p class="text-sm leading-normal">Kategoriler</p>
                </a>

                <a class="flex items-center gap-3 px-3 py-3 rounded-lg transition-all duration-300 @(currentController == "Product" ? "bg-white/20 border-l-4 border-white font-bold shadow-lg" : "hover:bg-white/10 hover:translate-x-1 text-red-100 hover:text-white")" href="/Admin/Product/Index">
                    <span class="material-symbols-outlined">bar_chart</span>
                    <p class="text-sm leading-normal">Ürünler</p>
                </a>

                <a class="flex items-center gap-3 px-3 py-3 rounded-lg transition-all duration-300 @(currentController == "Banner" ? "bg-white/20 border-l-4 border-white font-bold shadow-lg" : "hover:bg-white/10 hover:translate-x-1 text-red-100 hover:text-white")" href="/Admin/Banner/Index">
                    <span class="material-symbols-outlined">view_carousel</span>
                    <p class="text-sm leading-normal">Bannerlar</p>
                </a>

                <a class="flex items-center gap-3 px-3 py-3 rounded-lg transition-all duration-300 @(currentController == "Chef" ? "bg-white/20 border-l-4 border-white font-bold shadow-lg" : "hover:bg-white/10 hover:translate-x-1 text-red-100 hover:text-white")" href="/Admin/Chef/Index">
                    <span class="material-symbols-outlined">restaurant</span>
                    <p class="text-sm leading-normal">Şeflerimiz</p>
                </a>

                <a class="flex items-center gap-3 px-3 py-3 rounded-lg transition-all duration-300 @(currentController == "About" ? "bg-white/20 border-l-4 border-white font-bold shadow-lg" : "hover:bg-white/10 hover:translate-x-1 text-red-100 hover:text-white")" href="/Admin/About/Index">
                    <span class="material-symbols-outlined">info</span>
                    <p class="text-sm leading-normal">Hakkımızda</p>
                </a>

                <a class="flex items-center gap-3 px-3 py-3 rounded-lg transition-all duration-300 @(currentController == "Testimonial" ? "bg-white/20 border-l-4 border-white font-bold shadow-lg" : "hover:bg-white/10 hover:translate-x-1 text-red-100 hover:text-white")" href="/Admin/Testimonial/Index">
                    <span class="material-symbols-outlined">forum</span>
                    <p class="text-sm leading-normal">Yorumlar</p>
                </a>

                <a class="flex items-center gap-3 px-3 py-3 rounded-lg transition-all duration-300 @(currentController == "Blog" ? "bg-white/20 border-l-4 border-white font-bold shadow-lg" : "hover:bg-white/10 hover:translate-x-1 text-red-100 hover:text-white")" href="/Admin/Blog/Index">
                    <span class="material-symbols-outlined">article</span>
                    <p class="text-sm leading-normal">Blog</p>
                </a>

                <a class="flex items-center justify-between px-3 py-3 rounded-lg transition-all duration-300 @(currentController == "Contact" ? "bg-white/20 border-l-4 border-white font-bold shadow-lg" : "hover:bg-white/10 hover:translate-x-1 text-red-100 hover:text-white")" href="/Admin/Contact/Index">
                    <div class="flex items-center gap-3">
                        <span class="material-symbols-outlined">mail</span>
                        <p class="text-sm leading-normal">Mesajlar</p>
                    </div>
                    @if (unreadMessageCount > 0)
                    {
                        <span class="bg-white text-red-700 text-xs font-bold px-2 py-0.5 rounded-full shadow-md">@unreadMessageCount</span>
                    }
                </a>

                <a class="flex items-center justify-between px-3 py-3 rounded-lg transition-all duration-300 @(currentController == "Reservation" ? "bg-white/20 border-l-4 border-white font-bold shadow-lg" : "hover:bg-white/10 hover:translate-x-1 text-red-100 hover:text-white")" href="/Admin/Reservation/Index">
                    <div class="flex items-center gap-3">
                        <span class="material-symbols-outlined">calendar_month</span>
                        <p class="text-sm leading-normal">Rezervasyonlar</p>
                    </div>
                    @if (pendingReservationCount > 0)
                    {
                        <span class="bg-white text-red-700 text-xs font-bold px-2 py-0.5 rounded-full shadow-md">@pendingReservationCount</span>
                    }
                </a>
                <a class="flex items-center gap-3 px-3 py-3 rounded-lg transition-all duration-300 @(currentController == "Gallery" ? "bg-white/20 border-l-4 border-white font-bold shadow-lg" : "hover:bg-white/10 hover:translate-x-1 text-red-100 hover:text-white")" href="/Admin/Gallery/Index">
                    <span class="material-symbols-outlined">collections</span>
                    <p class="text-sm leading-normal">Galeri</p>
                </a>
                <a class="flex items-center gap-3 px-3 py-3 rounded-lg transition-all duration-300 @(currentController == "Settings" ? "bg-white/20 border-l-4 border-white font-bold shadow-lg" : "hover:bg-white/10 hover:translate-x-1 text-red-100 hover:text-white")" href="#">
                    <span class="material-symbols-outlined">settings</span>
                    <p class="text-sm leading-normal">Ayarlar</p>
                </a>
            </nav>
        </div>

        <div class="border-t border-red-400/30 pt-4 mt-4">
            <a class="flex items-center gap-3 px-3 py-3 rounded-lg transition-all duration-300 hover:bg-red-950/40 text-red-200 hover:text-white" href="/Login/Logout">
                <span class="material-symbols-outlined">logout</span>
                <p class="text-sm font-bold leading-normal">Çıkış Yap</p>
            </a>
        </div>
    </div>
</aside>