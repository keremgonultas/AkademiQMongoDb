@model AkademiQMongoDb.DTOs.ContactDtos.CreateContactDto
@{
    ViewData["Title"] = "İletişim";
    Layout = "~/Views/UILayout/Layout.cshtml";
}

<div class="breadcrumb-area text-center shadow text-light" style="background: linear-gradient(to right, #111111, #4a0000); padding-top: 170px; padding-bottom: 70px; margin-bottom: 50px;">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 offset-lg-2">
                <h1 style="font-size: 2.8rem; font-weight: 700; text-transform: none; margin-bottom: 10px;">Bize Ulaşın</h1>
                <ul class="breadcrumb" style="background: transparent; padding: 0; margin: 0; display: inline-flex; justify-content: center; font-size: 1.1rem;">
                    <li><a href="/Default/Index"><i class="fas fa-home"></i> Ana Sayfa</a></li>
                    <li>İletişim</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="maps-area overflow-hidden">
    <div class="google-maps">
        <iframe src="https://maps.google.com/maps?q=Kad%C4%B1k%C3%B6y,%20%C4%B0stanbul&t=&z=15&ie=UTF8&iwloc=&output=embed" width="100%" height="450" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
    </div>
    <div class="contact-style-one-items">
        <div class="container">
            <div class="contact-style-one-box">
                <div class="row">
                    <div class="col-lg-6">
                        <div class="contact-style-one-info">
                            <h2>Bizi Bulun</h2>
                            <p>
                                Lezzetli yemeklerimiz, sıcacık atmosferimiz ve güleryüzlü ekibimizle sizi ağırlamaktan mutluluk duyarız. Rezervasyon ve sorularınız için bize ulaşın.
                            </p>
                            <ul>
                                <li class="wow fadeInUp">
                                    <div class="icon">
                                        <i class="fas fa-phone-alt"></i>
                                    </div>
                                    <div class="content">
                                        <h5 class="title">Telefon</h5>
                                        <a href="tel:+905551234567">+90 555 123 45 67</a>
                                    </div>
                                </li>
                                <li class="wow fadeInUp" data-wow-delay="100ms">
                                    <div class="icon">
                                        <i class="fas fa-map-marker-alt"></i>
                                    </div>
                                    <div class="info">
                                        <h5 class="title">Adresimiz</h5>
                                        <p>
                                            Kadıköy <br> İstanbul / Türkiye
                                        </p>
                                    </div>
                                </li>
                                <li class="wow fadeInUp" data-wow-delay="200ms">
                                    <div class="icon">
                                        <i class="fas fa-envelope-open-text"></i>
                                    </div>
                                    <div class="info">
                                        <h5 class="title">E-Posta</h5>
                                        <a href="mailto:info@foodu.com">info@foodu.com</a>
                                    </div>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="contact-style-one-area default-padding overflow-hidden">
    <div class="container">
        <div class="row align-center">
            <div class="col-lg-12">
                <div class="contact-form-style-one">
                    <div class="heading text-center">
                        <h5 class="sub-title">İletişimde Kalalım</h5>
                        <h2 class="heading">Bize Mesaj Gönderin</h2>
                    </div>

                    <form action="/Contact/Index" method="post">
                        <div class="row">
                            <div class="col-lg-12">
                                <div class="form-group">
                                    <input class="form-control" asp-for="Name" placeholder="Adınız Soyadınız" type="text" required>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-lg-6">
                                <div class="form-group">
                                    <input class="form-control" asp-for="Email" placeholder="E-Posta Adresiniz *" type="email" required>
                                </div>
                            </div>
                            <div class="col-lg-6">
                                <div class="form-group">
                                    <input class="form-control" asp-for="Phone" placeholder="Telefon Numaranız" type="text" required>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-lg-12">
                                <div class="form-group comments">
                                    <textarea class="form-control" asp-for="Message" placeholder="Mesajınız *" rows="5" required></textarea>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-lg-12">
                                <button type="submit">
                                    <i class="fa fa-paper-plane"></i> Mesajı Gönder
                                </button>
                            </div>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

@if (TempData["SuccessMessage"] != null)
{
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            Swal.fire({
                title: 'Harika!',
                // Html.Raw ile Türkçe karakter sorununu çözdük
                text: '@Html.Raw(TempData["SuccessMessage"])',
                icon: 'success',
                confirmButtonText: 'Tamam',
                confirmButtonColor: '#4a0000'
            });
        });
    </script>
}