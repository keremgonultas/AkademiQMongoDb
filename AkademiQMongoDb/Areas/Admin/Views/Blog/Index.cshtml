@model List<AkademiQMongoDb.DTOs.BlogDtos.ResultBlogDto>
@{
    ViewData["Title"] = "Blog Yazıları";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int count = 0;
}

<div class="container-fluid p-6 bg-slate-50 min-h-screen font-sans">

    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
        <div>
            <h2 class="text-3xl font-extrabold text-slate-800 tracking-tight">Blog Yönetimi</h2>
            <p class="text-slate-500 mt-1">Müşterilerinizle paylaştığınız hikayeleri, makaleleri ve duyuruları buradan yönetebilirsiniz.</p>
        </div>

        <a href="/Admin/Blog/CreateBlog" class="group flex items-center gap-2 bg-cyan-600 hover:bg-cyan-700 text-white px-5 py-2.5 rounded-xl font-semibold shadow-md shadow-cyan-500/30 transition-all duration-300 hover:-translate-y-0.5">
            <span class="material-symbols-outlined text-xl transition-transform duration-300 group-hover:rotate-90">add</span>
            Yeni Blog Yazısı Ekle
        </a>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">

                <thead>
                    <tr class="bg-slate-50 border-b border-slate-100 text-slate-500 text-xs uppercase tracking-wider font-bold">
                        <th class="py-4 px-6 w-16 text-center">#</th>
                        <th class="py-4 px-6 w-32">Kapak Görseli</th>
                        <th class="py-4 px-6 w-1/3">Başlık</th>
                        <th class="py-4 px-6 w-40">Yazar</th>
                        <th class="py-4 px-6 w-40">Yayın Tarihi</th>
                        <th class="py-4 px-6 text-right w-48">İşlemler</th>
                    </tr>
                </thead>

                <tbody class="divide-y divide-slate-100">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            count++;
                            <tr class="hover:bg-slate-50 transition-colors duration-200 group">
                                <td class="py-4 px-6 text-center text-sm font-bold text-slate-400">@count</td>

                                <td class="py-4 px-6">
                                    <div class="w-24 h-14 rounded-lg overflow-hidden shadow-sm ring-1 ring-slate-200 bg-white">
                                        <img src="@item.ImageUrl" alt="@item.Title" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                                    </div>
                                </td>

                                <td class="py-4 px-6">
                                    <span class="text-sm font-bold text-slate-800 block truncate w-48 lg:w-72" title="@item.Title">
                                        @item.Title
                                    </span>
                                </td>

                                <td class="py-4 px-6">
                                    <span class="inline-flex items-center gap-1.5 text-xs font-bold text-slate-600 bg-slate-100 px-2.5 py-1 rounded-md border border-slate-200">
                                        <span class="material-symbols-outlined text-[14px] text-slate-400">history_edu</span>
                                        @item.Author
                                    </span>
                                </td>

                                <td class="py-4 px-6">
                                    <span class="inline-flex items-center gap-1 text-xs font-medium text-slate-500">
                                        <span class="material-symbols-outlined text-[16px] text-slate-400">calendar_month</span>
                                        @item.Date
                                    </span>
                                </td>

                                <td class="py-4 px-6">
                                    <div class="flex items-center justify-end gap-2">
                                        <a href="/Admin/Blog/UpdateBlog/@item.Id" class="flex items-center gap-1 px-3 py-2 bg-blue-50 text-blue-600 rounded-lg hover:bg-blue-600 hover:text-white transition-colors duration-300 shadow-sm">
                                            <span class="material-symbols-outlined text-[18px]">edit</span>
                                            <span class="text-xs font-bold hidden xl:block">Düzenle</span>
                                        </a>

                                        <a href="/Admin/Blog/DeleteBlog/@item.Id" onclick="return confirm('Bu blog yazısını silmek istediğinize emin misiniz?')" class="flex items-center gap-1 px-3 py-2 bg-red-50 text-red-600 rounded-lg hover:bg-red-600 hover:text-white transition-colors duration-300 shadow-sm">
                                            <span class="material-symbols-outlined text-[18px]">delete</span>
                                            <span class="text-xs font-bold hidden xl:block">Sil</span>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>

            @if (Model == null || !Model.Any())
            {
                <div class="p-10 text-center flex flex-col items-center justify-center">
                    <div class="w-16 h-16 bg-cyan-50 rounded-full flex items-center justify-center mb-4 ring-4 ring-cyan-100 border border-cyan-200">
                        <span class="material-symbols-outlined text-3xl text-cyan-500">article</span>
                    </div>
                    <p class="text-slate-500 font-medium">Sistemde henüz yayınlanmış bir blog yazısı bulunmuyor.</p>
                </div>
            }

        </div>
    </div>
</div>