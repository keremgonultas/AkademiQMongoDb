@model AkademiQMongoDb.DTOs.AboutDTOs.CreateAboutDto

@{
    ViewData["Title"] = "Yeni Hakkımızda Yazısı Ekle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid p-6 bg-slate-50 min-h-screen font-sans">

    <div class="mb-8">
        <div class="flex items-center gap-3 mb-2">
            <a href="/Admin/About/Index" class="w-10 h-10 flex items-center justify-center bg-white rounded-full border border-slate-200 text-slate-500 hover:text-indigo-600 hover:border-indigo-200 hover:shadow-sm transition-all duration-300">
                <span class="material-symbols-outlined text-[20px]">arrow_back</span>
            </a>
            <h2 class="text-3xl font-extrabold text-slate-800 tracking-tight">Yeni Hakkımızda Yazısı Ekle</h2>
        </div>
        <p class="text-slate-500 ml-13">Müşterilerinize restoranınızın hikayesini, misyonunu ve vizyonunu anlatacak yeni bir metin oluşturun.</p>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 w-full overflow-hidden">

        <div class="p-6 border-b border-slate-100 bg-slate-50/50">
            <h3 class="text-lg font-bold text-slate-700 flex items-center gap-2">
                <div class="w-8 h-8 rounded-lg bg-indigo-100 text-indigo-600 flex items-center justify-center">
                    <span class="material-symbols-outlined text-[18px]">corporate_fare</span>
                </div>
                Hakkımızda Detayları
            </h3>
        </div>

        <div class="p-8">
            <form method="post">

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                    <div class="md:col-span-1">
                        <label class="block text-sm font-bold text-slate-700 mb-2">
                            Üst Başlık (SubTitle) <span class="text-red-500 text-lg leading-none">*</span>
                        </label>
                        <div class="relative group">
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-indigo-500 transition-colors pointer-events-none">subtitles</span>
                            <input type="text" asp-for="SubTitle" class="w-full h-12 pl-12 pr-4 bg-slate-50 border border-slate-200 rounded-xl text-sm text-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 focus:bg-white transition-all duration-300" placeholder="Örn: Welcome To" required>
                        </div>
                        <span class="text-xs text-red-500 mt-1 block font-medium" asp-validation-for="SubTitle"></span>
                    </div>

                    <div class="md:col-span-1">
                        <label class="block text-sm font-bold text-slate-700 mb-2">
                            Ana Başlık (Title) <span class="text-red-500 text-lg leading-none">*</span>
                        </label>
                        <div class="relative group">
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-indigo-500 transition-colors pointer-events-none">title</span>
                            <input type="text" asp-for="Title" class="w-full h-12 pl-12 pr-4 bg-slate-50 border border-slate-200 rounded-xl text-sm text-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 focus:bg-white transition-all duration-300" placeholder="Örn: AkademiQ Restaurant" required>
                        </div>
                        <span class="text-xs text-red-500 mt-1 block font-medium" asp-validation-for="Title"></span>
                    </div>

                    <div class="md:col-span-1">
                        <label class="block text-sm font-bold text-slate-700 mb-2">
                            Görsel Linki (ImageUrl) <span class="text-red-500 text-lg leading-none">*</span>
                        </label>
                        <div class="relative group">
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-indigo-500 transition-colors pointer-events-none">image</span>
                            <input type="text" asp-for="ImageUrl" class="w-full h-12 pl-12 pr-4 bg-slate-50 border border-slate-200 rounded-xl text-sm text-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 focus:bg-white transition-all duration-300" placeholder="Örn: /UI/assets/img/about.jpg" required>
                        </div>
                        <span class="text-xs text-red-500 mt-1 block font-medium" asp-validation-for="ImageUrl"></span>
                    </div>

                    <div class="md:col-span-1">
                        <label class="block text-sm font-bold text-slate-700 mb-2">
                            Video Linki (YouTube vb.)
                        </label>
                        <div class="relative group">
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-indigo-500 transition-colors pointer-events-none">play_circle</span>
                            <input type="text" asp-for="VideoUrl" class="w-full h-12 pl-12 pr-4 bg-slate-50 border border-slate-200 rounded-xl text-sm text-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 focus:bg-white transition-all duration-300" placeholder="Örn: https://youtube.com/watch?v=...">
                        </div>
                        <span class="text-xs text-red-500 mt-1 block font-medium" asp-validation-for="VideoUrl"></span>
                    </div>

                    <div class="md:col-span-2">
                        <label class="block text-sm font-bold text-slate-700 mb-2">
                            Açıklama / Metin <span class="text-red-500 text-lg leading-none">*</span>
                        </label>
                        <div class="relative group">
                            <span class="material-symbols-outlined absolute left-4 top-4 text-slate-400 group-focus-within:text-indigo-500 transition-colors pointer-events-none">description</span>
                            <textarea asp-for="Description" rows="4" class="w-full pl-12 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm text-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 focus:bg-white transition-all duration-300 resize-y" placeholder="Müşterilerinize hikayenizi anlatın..." required></textarea>
                        </div>
                        <span class="text-xs text-red-500 mt-1 block font-medium" asp-validation-for="Description"></span>
                    </div>

                </div>

                <div class="mt-8 flex items-center gap-3 pt-6 border-t border-slate-100">
                    <button type="submit" class="flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-3 rounded-xl font-bold shadow-md shadow-indigo-500/30 transition-all duration-300 hover:-translate-y-0.5">
                        <span class="material-symbols-outlined text-[20px]">save</span>
                        Kaydet
                    </button>

                    <a href="/Admin/About/Index" class="flex items-center gap-2 bg-white border border-slate-200 text-slate-600 hover:text-slate-900 hover:bg-slate-50 px-6 py-3 rounded-xl font-bold transition-all duration-300">
                        <span class="material-symbols-outlined text-[20px]">close</span>
                        İptal Et
                    </a>
                </div>
            </form>
        </div>

    </div>
</div>