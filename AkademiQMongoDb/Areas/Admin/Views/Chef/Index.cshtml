@model List<AkademiQMongoDb.DTOs.ChefDTOs.ResultChefDto>

@{
    ViewData["Title"] = "Şef Listesi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int count = 0;
}

<div class="container-fluid p-6 bg-slate-50 min-h-screen font-sans">

    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
        <div>
            <h2 class="text-3xl font-extrabold text-slate-800 tracking-tight">Şef Yönetimi</h2>
            <p class="text-slate-500 mt-1">Mutfak ekibinizi, şeflerin unvanlarını ve durumlarını buradan yönetebilirsiniz.</p>
        </div>

        <a href="/Admin/Chef/CreateChef" class="group flex items-center gap-2 bg-orange-600 hover:bg-orange-700 text-white px-5 py-2.5 rounded-xl font-semibold shadow-md shadow-orange-500/30 transition-all duration-300 hover:-translate-y-0.5">
            <span class="material-symbols-outlined text-xl transition-transform duration-300 group-hover:rotate-90">add</span>
            Yeni Şef Ekle
        </a>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">

                <thead>
                    <tr class="bg-slate-50 border-b border-slate-100 text-slate-500 text-xs uppercase tracking-wider font-bold">
                        <th class="py-4 px-6 w-16 text-center">#</th>
                        <th class="py-4 px-6 w-24">PROFİL</th>
                        <th class="py-4 px-6 w-64">AD SOYAD</th>
                        <th class="py-4 px-6">UNVAN</th>
                        <th class="py-4 px-6 w-32">DURUM</th>
                        <th class="py-4 px-6 text-right w-48">İŞLEMLER</th>
                    </tr>
                </thead>

                <tbody class="divide-y divide-slate-100">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            count++;
                            <tr class="hover:bg-slate-50 transition-colors duration-200 group">
                                <td class="py-4 px-6 text-center text-sm font-bold text-slate-400">@count</td>

                                <td class="py-4 px-6">
                                    <div class="w-14 h-14 rounded-2xl overflow-hidden shadow-sm ring-2 ring-white border border-slate-100 bg-slate-50">
                                        <img src="@item.ImageUrl" alt="@item.Name" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                                    </div>
                                </td>

                                <td class="py-4 px-6">
                                    <span class="text-sm font-bold text-slate-800">@item.Name</span>
                                </td>

                                <td class="py-4 px-6">
                                    <span class="text-xs font-semibold text-slate-600 bg-slate-100 px-3 py-1.5 rounded-lg border border-slate-200">
                                        @item.Title
                                    </span>
                                </td>

                                <td class="py-4 px-6">
                                    @if (item.Status)
                                    {
                                        <span class="inline-flex items-center gap-1 bg-emerald-100 text-emerald-700 px-3 py-1.5 rounded-lg text-xs font-bold border border-emerald-200">
                                            <span class="material-symbols-outlined text-[14px]">check_circle</span>
                                            Aktif
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center gap-1 bg-red-100 text-red-700 px-3 py-1.5 rounded-lg text-xs font-bold border border-red-200">
                                            <span class="material-symbols-outlined text-[14px]">cancel</span>
                                            Pasif
                                        </span>
                                    }
                                </td>

                                <td class="py-4 px-6">
                                    <div class="flex items-center justify-end gap-2">
                                        <a href="/Admin/Chef/UpdateChef/@item.Id" class="flex items-center gap-1 px-3 py-2 bg-blue-50 text-blue-600 rounded-lg hover:bg-blue-600 hover:text-white transition-colors duration-300 shadow-sm">
                                            <span class="material-symbols-outlined text-[18px]">edit</span>
                                            <span class="text-xs font-bold hidden xl:block">Düzenle</span>
                                        </a>

                                        <a href="/Admin/Chef/DeleteChef/@item.Id" onclick="return confirm('@item.Name adlı şefi listeden silmek istediğinize emin misiniz?')" class="flex items-center gap-1 px-3 py-2 bg-red-50 text-red-600 rounded-lg hover:bg-red-600 hover:text-white transition-colors duration-300 shadow-sm">
                                            <span class="material-symbols-outlined text-[18px]">delete</span>
                                            <span class="text-xs font-bold hidden xl:block">Sil</span>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>

            @if (Model == null || !Model.Any())
            {
                <div class="p-10 text-center flex flex-col items-center justify-center">
                    <div class="w-16 h-16 bg-slate-50 rounded-full flex items-center justify-center mb-4 ring-4 ring-slate-50 border border-slate-100">
                        <span class="material-symbols-outlined text-3xl text-slate-400">restaurant</span>
                    </div>
                    <p class="text-slate-500 font-medium">Restoranınıza henüz bir şef kaydedilmemiş.</p>
                </div>
            }

        </div>
    </div>
</div>