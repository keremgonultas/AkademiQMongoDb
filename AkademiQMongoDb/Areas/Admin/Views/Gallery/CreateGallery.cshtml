@model AkademiQMongoDb.DTOs.GalleryDtos.CreateGalleryDto
@{
    ViewData["Title"] = "Yeni Görsel Ekle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="card shadow-sm">
        <div class="card-header bg-white">
            <div class="card-title font-weight-bold text-dark">Yeni Görsel Ekle</div>
        </div>
        <div class="card-body">
            <form method="post" action="/Admin/Gallery/CreateGallery">
                <div class="form-group">
                    <label>Görsel Yolu (URL)</label>
                    <input type="text" class="form-control" asp-for="ImageUrl" placeholder="/UI/assets/img/portfolio/1.jpg veya https://..." required>
                </div>

                <button type="submit" class="btn btn-primary mt-3"><i class="fas fa-save"></i> Kaydet</button>
                <a href="/Admin/Gallery/Index" class="btn btn-secondary mt-3 ml-2">İptal</a>
            </form>
        </div>
    </div>
</div>