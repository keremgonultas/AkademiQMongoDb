@model List<AkademiQMongoDb.DTOs.GalleryDtos.ResultGalleryDto>
@{
    ViewData["Title"] = "Galeri";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int count = 0;
}

<div class="container-fluid">
    <h4 class="page-title">Galeri Yönetimi</h4>
    <div class="card shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <div class="card-title font-weight-bold text-dark m-0">Restoran Fotoğrafları</div>
            <a href="/Admin/Gallery/CreateGallery" class="btn btn-primary"><i class="fas fa-plus"></i> Yeni Görsel Ekle</a>
        </div>
        <div class="card-body">
            <table class="table table-hover mt-3">
                <thead class="thead-light">
                    <tr>
                        <th>#</th>
                        <th>Görsel Önizleme</th>
                        <th>Görsel Yolu (URL)</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        count++;
                        <tr>
                            <td class="align-middle">@count</td>
                            <td class="align-middle">
                                <img src="@item.ImageUrl" alt="Galeri" style="height: 60px; width: 80px; object-fit: cover; border-radius: 5px; border: 1px solid #ddd;" />
                            </td>
                            <td class="align-middle">@item.ImageUrl</td>
                            <td class="align-middle">
                                <a href="/Admin/Gallery/UpdateGallery/@item.Id" class="btn btn-warning btn-sm"><i class="fas fa-pen"></i> Düzenle</a>
                                <a href="/Admin/Gallery/DeleteGallery/@item.Id" class="btn btn-danger btn-sm" onclick="return confirm('Bu görseli silmek istediğinize emin misiniz?');"><i class="fas fa-trash"></i> Sil</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>