@model AkademiQMongoDb.DTOs.GalleryDtos.UpdateGalleryDto
@{
    ViewData["Title"] = "Görsel Güncelle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="card shadow-sm">
        <div class="card-header bg-white">
            <div class="card-title font-weight-bold text-dark">Görsel Güncelle</div>
        </div>
        <div class="card-body">
            <form method="post" action="/Admin/Gallery/UpdateGallery">
                <input type="hidden" asp-for="Id" />

                <div class="form-group">
                    <label>Görsel Yolu (URL)</label>
                    <input type="text" class="form-control" asp-for="ImageUrl" required>
                </div>

                <div class="form-group mt-3">
                    <label>Mevcut Görsel:</label><br />
                    <img src="@Model.ImageUrl" style="height: 150px; border-radius: 8px; border: 1px solid #ccc;" />
                </div>

                <button type="submit" class="btn btn-warning mt-3"><i class="fas fa-pen"></i> Değişiklikleri Kaydet</button>
                <a href="/Admin/Gallery/Index" class="btn btn-secondary mt-3 ml-2">İptal</a>
            </form>
        </div>
    </div>
</div>