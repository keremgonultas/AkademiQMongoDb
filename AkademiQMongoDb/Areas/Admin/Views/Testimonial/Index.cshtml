@model List<AkademiQMongoDb.DTOs.TestimonialDTOs.ResultTestimonialDto>

@{
    ViewData["Title"] = "Müşteri Yorumları";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int count = 0;
}

<div class="container-fluid p-6 bg-slate-50 min-h-screen font-sans">

    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
        <div>
            <h2 class="text-3xl font-extrabold text-slate-800 tracking-tight">Müşteri Yorumları</h2>
            <p class="text-slate-500 mt-1">Misafirlerinizin restoranınız ve yemekleriniz hakkındaki geri bildirimlerini buradan yönetebilirsiniz.</p>
        </div>

        <a href="/Admin/Testimonial/CreateTestimonial" class="group flex items-center gap-2 bg-amber-500 hover:bg-amber-600 text-white px-5 py-2.5 rounded-xl font-semibold shadow-md shadow-amber-500/30 transition-all duration-300 hover:-translate-y-0.5">
            <span class="material-symbols-outlined text-xl transition-transform duration-300 group-hover:rotate-90">add</span>
            Yeni Yorum Ekle
        </a>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">

                <thead>
                    <tr class="bg-slate-50 border-b border-slate-100 text-slate-500 text-xs uppercase tracking-wider font-bold">
                        <th class="py-4 px-6 w-16 text-center">#</th>
                        <th class="py-4 px-6 w-24 text-center">Müşteri</th>
                        <th class="py-4 px-6 w-24 text-center">Yemek</th>
                        <th class="py-4 px-6">Başlık / Özet</th>
                        <th class="py-4 px-6 w-32">Durum</th>
                        <th class="py-4 px-6 text-right w-48">İşlemler</th>
                    </tr>
                </thead>

                <tbody class="divide-y divide-slate-100">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            count++;
                            <tr class="hover:bg-slate-50 transition-colors duration-200 group">
                                <td class="py-4 px-6 text-center text-sm font-bold text-slate-400">@count</td>

                                <td class="py-4 px-6 text-center">
                                    <div class="w-12 h-12 mx-auto rounded-full overflow-hidden shadow-sm ring-2 ring-amber-50 bg-white">
                                        <img src="@item.ImageUrl" alt="Müşteri" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                                    </div>
                                </td>

                                <td class="py-4 px-6 text-center">
                                    <div class="w-14 h-14 mx-auto rounded-lg overflow-hidden shadow-sm border border-slate-100 bg-white">
                                        <img src="@item.FoodImageUrl" alt="Yemek" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                                    </div>
                                </td>

                                <td class="py-4 px-6">
                                    <span class="text-sm font-bold text-slate-800 block truncate w-48 lg:w-72" title="@item.Title">
                                        @item.Title
                                    </span>
                                </td>

                                <td class="py-4 px-6">
                                    @if (item.Status)
                                    {
                                        <span class="inline-flex items-center gap-1 bg-emerald-100 text-emerald-700 px-3 py-1.5 rounded-lg text-xs font-bold border border-emerald-200">
                                            <span class="material-symbols-outlined text-[14px]">check_circle</span>
                                            Aktif
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center gap-1 bg-red-100 text-red-700 px-3 py-1.5 rounded-lg text-xs font-bold border border-red-200">
                                            <span class="material-symbols-outlined text-[14px]">visibility_off</span>
                                            Gizli
                                        </span>
                                    }
                                </td>

                                <td class="py-4 px-6">
                                    <div class="flex items-center justify-end gap-2">
                                        <a href="/Admin/Testimonial/UpdateTestimonial/@item.Id" class="flex items-center gap-1 px-3 py-2 bg-blue-50 text-blue-600 rounded-lg hover:bg-blue-600 hover:text-white transition-colors duration-300 shadow-sm">
                                            <span class="material-symbols-outlined text-[18px]">edit</span>
                                            <span class="text-xs font-bold hidden xl:block">Düzenle</span>
                                        </a>

                                        <a href="/Admin/Testimonial/DeleteTestimonial/@item.Id" onclick="return confirm('Bu yorumu silmek istediğinize emin misiniz?')" class="flex items-center gap-1 px-3 py-2 bg-red-50 text-red-600 rounded-lg hover:bg-red-600 hover:text-white transition-colors duration-300 shadow-sm">
                                            <span class="material-symbols-outlined text-[18px]">delete</span>
                                            <span class="text-xs font-bold hidden xl:block">Sil</span>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>

            @if (Model == null || !Model.Any())
            {
                <div class="p-10 text-center flex flex-col items-center justify-center">
                    <div class="w-16 h-16 bg-amber-50 rounded-full flex items-center justify-center mb-4 ring-4 ring-amber-100 border border-amber-200">
                        <span class="material-symbols-outlined text-3xl text-amber-500">reviews</span>
                    </div>
                    <p class="text-slate-500 font-medium">Sistemde henüz kayıtlı bir müşteri yorumu bulunmuyor.</p>
                </div>
            }

        </div>
    </div>
</div>